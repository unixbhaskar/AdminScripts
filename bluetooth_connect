#!/usr/bin/env bash

# Check if Bluetooth service is up or not

if test $(find_init) == "SYSVINIT" && $(pidof bluetoothd) -eq 0;then
	sudo /etc/init.d/bluetooth start
elif test $(find_init) == "SYSTEMD" && $(pidof bluetoothd) -eq 0;then
	sudo systemctl start bluetooth.service
fi

# The MAC address of the Bluetooth device to pair
device="79:99:CA:0C:C3:44"

# Start the process
echo -e "power on\nagent on\ndefault-agent\npair $device\nconnect $device\nquit" | bluetoothctl

notify-send "Connected To : $(bluetoothctl devices Connected)"
